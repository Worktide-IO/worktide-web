{"type":"object","description":"Per-user weekly working capacity in MINUTES per weekday. Replaces awork's\n`UserWeeklyCapacity` object — flattened into the row so reporting queries\ndon't need to join an embedded.\n\nOne row per user, enforced by the unique constraint on user_id. Default\n= 0 minutes everywhere; UI should pre-fill 480 (8h) on weekdays for new\nusers.","properties":{"user":{"type":"string","format":"iri-reference","example":"https://example.com/"},"monMinutes":{"default":0,"type":"integer"},"tueMinutes":{"default":0,"type":"integer"},"wedMinutes":{"default":0,"type":"integer"},"thuMinutes":{"default":0,"type":"integer"},"friMinutes":{"default":0,"type":"integer"},"satMinutes":{"default":0,"type":"integer"},"sunMinutes":{"default":0,"type":"integer"},"id":{"readOnly":true,"type":["string","null"],"format":"uuid"},"createdAt":{"readOnly":true,"type":"string","format":"date-time"},"updatedAt":{"readOnly":true,"type":"string","format":"date-time"},"version":{"readOnly":true,"default":1,"type":"integer"},"createdByUser":{"type":["string","null"],"format":"iri-reference","example":"https://example.com/"},"updatedByUser":{"type":["string","null"],"format":"iri-reference","example":"https://example.com/"},"weeklyMinutes":{"readOnly":true,"type":"integer"}},"x-readme-ref-name":"UserCapacity.html"}