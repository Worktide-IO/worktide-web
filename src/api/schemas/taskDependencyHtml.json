{"type":"object","description":"Directional precedence relation between two tasks within the same project.\n\nBeyond awork: we keep `type` (the four classic PM dependency variants) and\n`lagMinutes` so Gantt-style scheduling has the data it needs without a\nschema change later. Cycle detection runs in the controller before persist.","properties":{"predecessor":{"type":"string","format":"iri-reference","example":"https://example.com/"},"successor":{"type":"string","format":"iri-reference","example":"https://example.com/"},"type":{"default":"finish_to_start","type":"string","enum":["finish_to_start","start_to_start","finish_to_finish","start_to_finish"]},"lagMinutes":{"description":"Delay (positive) or lead (negative) in minutes between the linked endpoints.","default":0,"type":"integer"},"id":{"readOnly":true,"type":["string","null"],"format":"uuid"},"createdAt":{"readOnly":true,"type":"string","format":"date-time"},"updatedAt":{"readOnly":true,"type":"string","format":"date-time"},"workspace":{"type":"string","format":"iri-reference","example":"https://example.com/"},"version":{"readOnly":true,"default":1,"type":"integer"},"createdByUser":{"type":["string","null"],"format":"iri-reference","example":"https://example.com/"},"updatedByUser":{"type":["string","null"],"format":"iri-reference","example":"https://example.com/"}},"x-readme-ref-name":"TaskDependency.html"}