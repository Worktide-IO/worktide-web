# Where the data + auth providers hit the Worktide API.
# Dev default `/v1` is proxied by Vite to https://api.worktide.ddev.site.
# Production: point this at the real backend, e.g.
#   VITE_API_BASE=https://api.worktide.example.com/v1
VITE_API_BASE=/v1

# Public, absolute URL of the API for building Mercure topic IRIs.
# API Platform publishes topics like `${VITE_API_PUBLIC_BASE}/customers/<uuid>`,
# so subscribers must match the same prefix. In dev this is the DDEV host
# even though VITE_API_BASE is the proxied `/v1` shortcut.
VITE_API_PUBLIC_BASE=https://api.worktide.ddev.site/v1

# The Mercure hub on Coolify. Same URL is used by both the backend
# (server-to-server publish) and the frontend (EventSource subscribe).
VITE_MERCURE_HUB_URL=https://worktide-mercure.wappler.systems/.well-known/mercure
